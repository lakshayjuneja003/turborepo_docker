{
  "name": "DEVOPS_2",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:generate":"cd packages/db && bunx prisma@6.10.1 generate && cd ../..",
    "start:backend:migrate": "bunx prisma@6.10.1 migrate deploy --schema=packages/db/prisma/schema.prisma && bun run apps/backend/index.ts",
    
    "start:web":"cd apps/web && bun run start",
    "start:ws":"cd apps/ws && bun run index.ts"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.10.5",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "1.3.14"
    }
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
